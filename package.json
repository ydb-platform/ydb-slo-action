{
	"name": "@ydb-platform/ydb-slo-action",
	"type": "module",
	"scripts": {
		"prebundle": "rm -rf dist",
		"bundle": "bun build init/main.ts init/post.ts report/main.ts --target=node --format=esm --splitting --minify-syntax --sourcemap=none --outdir dist",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"test:coverage": "bun test --coverage",
		"format": "bunx --bun oxfmt **/*.ts --write",
		"lint": "bunx --bun oxlint **/*.ts --fix"
	},
	"dependencies": {
		"@actions/artifact": "^6.2.1",
		"@actions/core": "^3.0.0",
		"@actions/exec": "^3.0.0",
		"@actions/github": "^9.0.0"
	},
	"devDependencies": {
		"husky": "^9.1.7",
		"oxfmt": "0.45.0",
		"oxlint": "^1.57.0"
	},
	"peerDependencies": {
		"typescript": "^5.9.3"
	},
	"lint-staged": {
		"**/*.{ts,json,md}": [
			"bun run --bun oxlint --fix",
			"bun run --bun oxfmt --write"
		]
	},
	"packageManager": "bun@1.3.3"
}
