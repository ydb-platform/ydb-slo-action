# YDB SLO Action - Environment Variables
# Copy this file to .env and adjust values as needed

# Workload Configuration
# Duration in seconds (0 = unlimited)
WORKLOAD_DURATION=0

# Workload Docker Images
# Override these to use custom workload images
WORKLOAD_CURRENT_IMAGE=ydb-workload-current
WORKLOAD_BASELINE_IMAGE=ydb-workload-baseline

# Workload Commands (optional)
# Override the default command/entrypoint for workload containers
# If the image has ENTRYPOINT, command will be appended as arguments
# If the image only has CMD, entire command will be replaced
# Leave empty to use the image's default CMD/ENTRYPOINT
#
# Examples with arguments:
#   WORKLOAD_CURRENT_COMMAND=--threads 10 --duration 300
#   WORKLOAD_CURRENT_COMMAND=--verbose --mode stress --connections 100
#
# Examples with full command:
#   WORKLOAD_BASELINE_COMMAND=/app/workload --verbose
#   WORKLOAD_BASELINE_COMMAND=/bin/sh -c "sleep 10 && /app/workload"
#
WORKLOAD_CURRENT_COMMAND=
WORKLOAD_BASELINE_COMMAND=

# Example: Using node-checker as workload
# Build the image first: cd app && docker build -t ydb-node-checker .
# WORKLOAD_CURRENT_IMAGE=ydb-node-checker
# WORKLOAD_CURRENT_COMMAND=--nodes "ydb-database-1 ydb-database-2" --interval 5 --duration 300 --prometheus-url http://ydb-prometheus:9090

# Note: The following variables are pre-configured in compose.yml
# and passed to workload containers automatically:
#   YDB_CONNECTION_STRING=grpc://ydb:2136/Root/testdb (recommended)
#   YDB_ENDPOINT=grpc://ydb:2136 (legacy)
#   YDB_DATABASE=/Root/testdb (legacy)
#   PROMETHEUS_URL=http://ydb-prometheus:9090
#   PROMETHEUS_QUERY_URL=http://ydb-prometheus:9090/api/v1/query
#   PROMETHEUS_REMOTE_WRITE_URL=http://ydb-prometheus:9090/api/v1/write
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://ydb-prometheus:9090/api/v1/otlp

# Example usage:
# 1. Copy this file: cp env.example .env
# 2. Edit .env with your values
# 3. Run: docker compose --profile telemetry --profile workload-current up
#
# Or override from command line:
#   WORKLOAD_DURATION=300 docker compose --profile workload-current up
#   WORKLOAD_CURRENT_IMAGE=my-workload docker compose --profile workload-current up
#   WORKLOAD_CURRENT_COMMAND="--threads 20" docker compose --profile workload-current up
#
# Combine multiple variables:
#   WORKLOAD_CURRENT_IMAGE=my-workload \
#   WORKLOAD_CURRENT_COMMAND="--verbose --threads 10" \
#   WORKLOAD_DURATION=300 \
#   docker compose --profile telemetry --profile workload-current up
#
# Using node-checker as workload:
#   WORKLOAD_CURRENT_IMAGE=ydb-node-checker \
#   WORKLOAD_CURRENT_COMMAND="--interval 5 --duration 300 --prometheus-url http://ydb-prometheus:9090" \
#   docker compose --profile telemetry --profile workload-current up
#
# Run both current and baseline workloads simultaneously:
#   WORKLOAD_CURRENT_IMAGE=my-workload:pr-123 \
#   WORKLOAD_BASELINE_IMAGE=my-workload:main \
#   WORKLOAD_CURRENT_COMMAND="--threads 20" \
#   WORKLOAD_BASELINE_COMMAND="--threads 10" \
#   docker compose --profile telemetry --profile workloads up
